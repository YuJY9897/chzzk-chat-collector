# 치지직 개발자 센터(developers.chzzk.naver.com)에서 발급
CHZZK_CLIENT_ID=
CHZZK_CLIENT_SECRET=

# 개발자 센터에 등록한 Redirect URI와 동일해야 함
CHZZK_REDIRECT_URI=http://localhost:3000/callback

# CLI 인증(npm run auth:token) 후 발급받은 토큰 (웹앱만 쓰면 비워둬도 됨)
CHZZK_ACCESS_TOKEN=
CHZZK_REFRESH_TOKEN=

# 수집 시작 시 refresh token으로 access token 자동 갱신 여부
AUTO_REFRESH_TOKEN=true

# CLI 수집(npm run collect) 기본값
BROADCAST_TITLE=broadcast
BROADCAST_STARTED_AT=
OUTPUT_DIR=./data
